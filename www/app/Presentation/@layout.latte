<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Vysočany Map</title>

	<style>
		:root {
			font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
			line-height: 1.5;
			color: #222;
		}

		body {
			margin: 0;
			padding: 1.5rem;
			max-width: 1100px;
			margin-inline: auto;
		}

		h1 {
			margin-top: 0;
		}

		.flash {
			padding: 0.75rem 1rem;
			border-radius: 6px;
			margin-bottom: 1rem;
		}

		.flash.info { background: #e8f4fd; }
		.flash.success { background: #e8f8ef; }
		.flash.error { background: #fdecea; }
	</style>

	{asset? 'main.js'}
</head>

<body>
	<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">{$flash->message}</div>

	{include content}
</body>
</html>
